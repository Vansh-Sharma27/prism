# Backend Environment Variables
# Copy to .env and fill in values

# Flask
FLASK_APP=app
FLASK_ENV=development
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ACCESS_TOKEN_EXPIRES=3600
PRISM_AUTO_CREATE_TABLES=false
PRISM_ALLOW_PUBLIC_READS=false
PRISM_ALLOW_PRIVILEGED_SELF_REGISTER=false
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_URL=postgresql://prism_user:password@localhost:5432/prism_db
PRISM_REDIS_URL=redis://localhost:6379/0
PRISM_RATE_LIMIT_STORAGE_URI=redis://localhost:6379/0
PRISM_NOTIFICATIONS_BACKEND=redis
PRISM_NOTIFICATIONS_REDIS_CHANNEL=prism:notifications
PRISM_REDIS_BIND_ADDRESS=127.0.0.1
PRISM_REDIS_BIND_PORT=6379

# MQTT
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
PRISM_MQTT_BIND_ADDRESS=127.0.0.1
PRISM_MQTT_BIND_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ML Model
ML_MODEL_PATH=../ml/models/occupancy_predictor.pkl

# Logging
LOG_LEVEL=DEBUG
