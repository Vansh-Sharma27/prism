# PRISM Frontend Configuration

# Backend API URL seen by browser
# Use same-origin proxy by default (recommended for headless VM deployment).
NEXT_PUBLIC_API_URL=/api/v1

# Internal backend origin for Next.js rewrite target
PRISM_BACKEND_URL=http://127.0.0.1:5000

# Optional bearer token for protected backend endpoints.
# You can also set this in browser localStorage as `prism_access_token`.
NEXT_PUBLIC_API_TOKEN=
